# ─── Meridian Environment Configuration ───

# ─── Database ───
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=meridian
POSTGRES_USER=meridian
POSTGRES_PASSWORD=meridian_dev_password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Redis ───
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ─── Stellar ───
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Services ───
API_HOST=0.0.0.0
API_PORT=8000
GRAPH_ENGINE_HOST=0.0.0.0
GRAPH_ENGINE_PORT=8001
ROUTE_OPTIMIZER_HOST=0.0.0.0
ROUTE_OPTIMIZER_PORT=8002
QUALITY_ORACLE_HOST=0.0.0.0
QUALITY_ORACLE_PORT=8003
PREDICTIVE_ENGINE_HOST=0.0.0.0
PREDICTIVE_ENGINE_PORT=8004
INGESTION_HOST=0.0.0.0
INGESTION_PORT=8005

# ─── Internal Service URLs ───
GRAPH_ENGINE_URL=http://graph-engine:8001
ROUTE_OPTIMIZER_URL=http://route-optimizer:8002
QUALITY_ORACLE_URL=http://quality-oracle:8003
PREDICTIVE_ENGINE_URL=http://predictive-engine:8004
INGESTION_URL=http://ingestion:8005

# ─── Auth ───
API_KEY_HEADER=X-Meridian-API-Key
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── Logging ───
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Ingestion ───
INGESTION_ORDERBOOK_POLL_INTERVAL=30
INGESTION_POOL_SYNC_INTERVAL=60
INGESTION_ASSET_DISCOVERY_INTERVAL=300
INGESTION_MAX_ORDERBOOK_DEPTH=50
